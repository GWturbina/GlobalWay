<script>
// Функция добавления токена в кошелек
async function addTokenToWallet() {
    if (!window.ethereum) {
        UI.showNotification('Please connect your wallet first', 'warning');
        return;
    }
    
    try {
        const wasAdded = await window.ethereum.request({
            method: 'wallet_watchAsset',
            params: {
                type: 'ERC20',
                options: {
                    address: '0x5Bf1b9edD3914f546AC02cf35CC285E640Cb68Fc',
                    symbol: 'GWT',
                    decimals: 18,
                    image: window.location.origin + '/assets/icons/icon-192x192.png'
                }
            }
        });
        
        if (wasAdded) {
            UI.showNotification('Token added successfully!', 'success');
        }
    } catch (error) {
        console.error('Error adding token:', error);
        UI.showNotification('Error adding token', 'error');
    }
}
</script>
