<!-- Dashboard Component -->
<div class="dashboard-content">
 <!-- User Info Card -->
 <div class="cosmic-card">
   <h3>🌌 <span data-translate="personal_account">Personal Account</span></h3>
   <div class="user-info-grid">
     <div class="info-item">
       <span class="label" data-translate="wallet_address">Address:</span>
       <span id="userAddress" class="value">0x000...000</span>
     </div>
     <div class="info-item">
       <span class="label" data-translate="balance">Balance:</span>
       <span id="userBalance" class="value">0.000 BNB</span>
     </div>
     <div class="info-item">
       <span class="label" data-translate="user_id">ID:</span>
       <span id="userId" class="value">---</span>
     </div>
     <div class="info-item">
       <span class="label" data-translate="rank">Rank:</span>
       <span id="userRank" class="value">---</span>
     </div>
     <div class="info-item">
       <span class="label" data-translate="referral_from">Referral from:</span>
       <span id="referralFrom" class="value">---</span>
     </div>
     <div class="info-item">
       <span class="label" data-translate="total_earned">Total Earned:</span>
       <span id="totalEarned" class="value">0.000 BNB</span>
     </div>
   </div>
   
   <div class="referral-section">
     <label data-translate="referral_link">Referral Link:</label>
     <div class="referral-input-group">
       <input type="text" id="referralLink" readonly>
       <button id="copyRefLink" class="copy-btn">📋</button>
     </div>
   </div>
 </div>
 
 <!-- Квартальная активность -->
 <div class="cosmic-card">
   <h3>⏰ <span data-translate="quarterly_activity">Quarterly Activity</span></h3>
   <div class="user-info-grid">
     <div class="info-item">
       <span class="label" data-translate="quarter_number">Quarter:</span>
       <span id="quarterNumber" class="value">1</span>
     </div>
     <div class="info-item">
       <span class="label" data-translate="last_payment">Last Payment:</span>
       <span id="lastQuarterlyPayment" class="value">---</span>
     </div>
     <div class="info-item">
       <span class="label" data-translate="next_payment">Next Payment:</span>
       <span id="nextQuarterlyDate" class="value">---</span>
     </div>
     <div class="info-item">
       <span class="label" data-translate="quarterly_fee">Fee:</span>
       <span id="quarterlyFeeAmount" class="value">0.075 BNB</span>
     </div>
   </div>
   
   <button id="payQuarterlyBtn" class="activate-btn" disabled>
     💰 <span data-translate="pay_quarterly">Pay Quarterly Activity</span>
   </button>
   
   <div id="quarterlyStatus" class="status-item">
     <span class="label" data-translate="status">Status:</span>
     <span class="value active">✅ Active (checking...)</span>
   </div>
 </div>
 
 <!-- Auto Upgrade -->
 <div class="cosmic-card">
   <h3>🔄 <span data-translate="auto_upgrade">Auto Upgrade</span></h3>
   <div class="toggle-container">
     <label class="cosmic-toggle">
       <input type="checkbox" id="autoUpgrade">
       <span class="toggle-slider"></span>
     </label>
     <span class="toggle-label" data-translate="enabled">Enabled</span>
   </div>
 </div>
 
