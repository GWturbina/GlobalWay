 <!-- GWT Tokens -->
 <div class="cosmic-card">
   <h3>🪙 <span data-translate="gwt_tokens">GWT Tokens</span></h3>
   <div class="token-section">
     <div class="token-balance-display">
       <span id="tokenBalance" class="token-amount">0 GWT</span>
       <span id="tokenValue" class="token-value">≈ $0.00</span>
     </div>
     <div class="token-price-info">
       <span data-translate="current_price">Current Price:</span>
